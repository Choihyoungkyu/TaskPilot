# ============================================
# Kakao OAuth Configuration
# REQUIRED: Get these from https://developers.kakao.com
# ============================================
KAKAO_CLIENT_ID=your_kakao_client_id_here
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here
KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback

# ============================================
# JWT Configuration
# Change this to a strong secret in production
# ============================================
JWT_SECRET=your-super-secret-key-that-must-be-at-least-256-bits-long-for-hs256-algorithm-security-requirement
JWT_EXPIRATION=86400000

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskpilot
DB_USER=admin
DB_PASSWORD=admin

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=8080
FRONTEND_PORT=3000

# ============================================
# OpenAI Configuration (for future use)
# Get API key from https://platform.openai.com/api-keys
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# Kakao Bot Webhook (for future use)
# ============================================
KAKAO_BOT_WEBHOOK_URL=https://example.kakao.com/webhook
